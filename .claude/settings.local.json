{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "Bash(claude:*)",
      "Bash(obsidian:*)",
      "Bash(tasklist)"
    ]
  },
  "memory": {
    "path": ".claude/memory.md",
    "autoMemory": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/context-warn.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/auto-review.mjs"
          }
        ]
      }
    ]
  }
}